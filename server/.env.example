# ─────────────────────────────────────────────
# CodeShield Server — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# AI Provider — set ONE of the following:
# Option A: Anthropic (Claude)
#ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B: Groq
GROQ_API_KEY=your_groq_api_key_here

# AI Provider selection: "anthropic" | "groq" | "none"
AI_PROVIDER=groq

# API key to protect /analyze endpoint (optional)
# If set, clients must send header: x-api-key: <value>
API_KEY=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (requests per windowMs)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

# Max request payload
MAX_PAYLOAD_SIZE=500kb
